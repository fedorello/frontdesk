# Copy to `.env` (gitignored) for `docker compose --profile app up`.
# Only the LLM key is needed to see the assistant work; the channel tokens are
# for connecting real WhatsApp / Telegram.

# LLM (model-agnostic; any OpenAI-compatible or Anthropic endpoint)
FRONTDESK_LLM_PROVIDER=openai
FRONTDESK_LLM_API_KEY=sk-or-...
FRONTDESK_LLM_MODEL=deepseek/deepseek-v4-flash
FRONTDESK_LLM_BASE_URL=https://openrouter.ai/api/v1

# WhatsApp Cloud API
FRONTDESK_WHATSAPP_TOKEN=
FRONTDESK_WHATSAPP_PHONE_NUMBER_ID=
FRONTDESK_WHATSAPP_APP_SECRET=
FRONTDESK_WHATSAPP_VERIFY_TOKEN=

# Telegram Bot API
FRONTDESK_TELEGRAM_TOKEN=
FRONTDESK_TELEGRAM_SECRET=
FRONTDESK_TELEGRAM_BOT_ADDRESS=
